
import rclpy
from rclpy.node import Node
from enum import Enum
from std_msgs.msg import String
import numpy as np

class Status(Enum):
    HEALTHY = 1
    NO_CONNECTION = 2
    ANOMALOUS = 3
    FAULTY = 4
    FATAL = 5


class System_Health_Manager(Node):
    def __init__(self):

        self.initialising = True
        self.fault_tolerance = 10
        self.fatal_tolerance = 100

