        self._SystemHealthCheck('Simulation') = self.node_status['clock']

    
    def _SystemHealthCheck(self,system,nodes):

        # Init counters
        health = 0
        anom = 0
        offline = 0
        num_nodes = len(nodes)

        for node in nodes:
            if self.node_status[node] == Status.HEALTHY: health+=1
            elif self.node_status[node] == Status.NO_CONNECTION: offline+1
            elif self.node_status[node] == Status.ANOMALOUS: anom += 1
            else:
                # If ANY node is Faulty, throw an immediate fatal error - it should not be acting
                # All further actions should be blocked - and to stop the subscriber. 
                self.systems_status[system] = Status.FATAL
                # Throw immediate fatal error
                return

        # If all nodes are healthy, then the system is healthy
        if num_nodes == health:
            self.systems_status[system] = Status.HEALTHY

        # If all nodes haven't sent any messages (Meaning no status change), then it's offline
        elif num_nodes == offline:
            self.systems_status[system] = Status.NO_CONNECTION

        # If less than 25% of the nodes are anomlous, maintain system, mark as anomalous
        elif (offline != 0) or (anom / num_nodes) <= 0.25:
            # Notify issue
            self.systems_status[system] = Status.ANOMALOUS
        
        # Otherwise, more than 25% of nodes are reporting anomalous at the SAME TIME, mark as faulty, begin shutdown procedures
        else:
            # Update system to show faulty state
            self.systems_status[system] = Status.FATAL

            # By setting the last node accessed to FAULTY, it will automatically re-trigger the fault detection next loop
            self.node_status[node] = Status.FATAL

