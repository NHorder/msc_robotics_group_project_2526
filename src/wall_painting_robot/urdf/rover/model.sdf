<?xml version="1.0" ?>
<sdf version="1.9">
  <model name="visnat">
    <static>false</static>

    <link name="base_footprint"/>
    <joint name="footprint_joint" type="fixed">
      <parent>base_footprint</parent>
      <child>base_link</child>
    </joint>

    <!-- ================================================================ -->
    <!--  MOBILE BASE                                                       -->
    <!-- ================================================================ -->
    <link name="base_link">
      <pose relative_to="base_footprint">0 0 0.1 0 0 0</pose>
      <inertial>
        <mass>200</mass>
        <inertia><ixx>50.0</ixx><iyy>50.0</iyy><izz>80.0</izz></inertia>
      </inertial>
      <collision name="base_collision">
        <pose>0 0 0.07 0 0 0</pose>
        <geometry><box><size>0.6 0.6 0.06</size></box></geometry>
      </collision>
      <visual name="base_visual">
        <geometry>
          <mesh><uri>model://visnat/base.stl</uri><scale>0.002 0.002 0.002</scale></mesh>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse>
          <specular>0.2 0.2 0.2 1</specular>
        </material>
      </visual>
    </link>

    <!-- WHEELS -->
    <link name="wheel_fl">
      <pose relative_to="joint_fl">0 0 0 0 0 0</pose>
      <inertial><mass>1.0</mass><inertia><ixx>0.005</ixx><iyy>0.005</iyy><izz>0.005</izz></inertia></inertial>
      <visual name="wheel_fl_visual"><geometry><mesh><uri>model://visnat/wheel.stl</uri><scale>0.002 0.002 0.002</scale></mesh></geometry><material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material></visual>
      <collision name="wheel_fl_collision"><pose>0 0 0 1.5708 0 0</pose><geometry><cylinder><radius>0.1</radius><length>0.05</length></cylinder></geometry><surface><friction><ode><mu>2.0</mu><mu2>2.0</mu2><fdir1>1 0 0</fdir1></ode></friction><contact><ode><min_depth>0.001</min_depth><max_vel>0.1</max_vel></ode></contact></surface></collision>
    </link>
    <joint name="joint_fl" type="revolute">
      <parent>base_link</parent><child>wheel_fl</child>
      <pose relative_to="base_link">0.5 0.65 0.0 0 0 0</pose>
      <axis><xyz>0 1 0</xyz><limit><lower>-1e+16</lower><upper>1e+16</upper><effort>100</effort><velocity>100</velocity></limit><dynamics><damping>0.05</damping></dynamics><use_parent_model_frame>1</use_parent_model_frame></axis>
    </joint>

    <link name="wheel_fr">
      <pose relative_to="joint_fr">0 0 0 0 0 0</pose>
      <inertial><mass>1.0</mass><inertia><ixx>0.005</ixx><iyy>0.005</iyy><izz>0.005</izz></inertia></inertial>
      <visual name="wheel_fr_visual"><geometry><mesh><uri>model://visnat/wheel.stl</uri><scale>0.002 0.002 0.002</scale></mesh></geometry><material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material></visual>
      <collision name="wheel_fr_collision"><pose>0 0 0 1.5708 0 0</pose><geometry><cylinder><radius>0.1</radius><length>0.05</length></cylinder></geometry><surface><friction><ode><mu>2.0</mu><mu2>2.0</mu2><fdir1>1 0 0</fdir1></ode></friction><contact><ode><min_depth>0.001</min_depth><max_vel>0.1</max_vel></ode></contact></surface></collision>
    </link>
    <joint name="joint_fr" type="revolute">
      <parent>base_link</parent><child>wheel_fr</child>
      <pose relative_to="base_link">0.5 -0.65 0.0 0 0 0</pose>
      <axis><xyz>0 1 0</xyz><limit><lower>-1e+16</lower><upper>1e+16</upper><effort>100</effort><velocity>100</velocity></limit><dynamics><damping>0.05</damping></dynamics><use_parent_model_frame>1</use_parent_model_frame></axis>
    </joint>

    <link name="wheel_bl">
      <pose relative_to="joint_bl">0 0 0 0 0 0</pose>
      <inertial><mass>1.0</mass><inertia><ixx>0.005</ixx><iyy>0.005</iyy><izz>0.005</izz></inertia></inertial>
      <visual name="wheel_bl_visual"><geometry><mesh><uri>model://visnat/wheel.stl</uri><scale>0.002 0.002 0.002</scale></mesh></geometry><material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material></visual>
      <collision name="wheel_bl_collision"><pose>0 0 0 1.5708 0 0</pose><geometry><cylinder><radius>0.1</radius><length>0.05</length></cylinder></geometry><surface><friction><ode><mu>2.0</mu><mu2>2.0</mu2><fdir1>1 0 0</fdir1></ode></friction><contact><ode><min_depth>0.001</min_depth><max_vel>0.1</max_vel></ode></contact></surface></collision>
    </link>
    <joint name="joint_bl" type="revolute">
      <parent>base_link</parent><child>wheel_bl</child>
      <pose relative_to="base_link">-0.5 0.65 0.0 0 0 0</pose>
      <axis><xyz>0 1 0</xyz><limit><lower>-1e+16</lower><upper>1e+16</upper><effort>100</effort><velocity>100</velocity></limit><dynamics><damping>0.05</damping></dynamics><use_parent_model_frame>1</use_parent_model_frame></axis>
    </joint>

    <link name="wheel_br">
      <pose relative_to="joint_br">0 0 0 0 0 0</pose>
      <inertial><mass>1.0</mass><inertia><ixx>0.005</ixx><iyy>0.005</iyy><izz>0.005</izz></inertia></inertial>
      <visual name="wheel_br_visual"><geometry><mesh><uri>model://visnat/wheel.stl</uri><scale>0.002 0.002 0.002</scale></mesh></geometry><material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material></visual>
      <collision name="wheel_br_collision"><pose>0 0 0 1.5708 0 0</pose><geometry><cylinder><radius>0.1</radius><length>0.05</length></cylinder></geometry><surface><friction><ode><mu>2.0</mu><mu2>2.0</mu2><fdir1>1 0 0</fdir1></ode></friction><contact><ode><min_depth>0.001</min_depth><max_vel>0.1</max_vel></ode></contact></surface></collision>
    </link>
    <joint name="joint_br" type="revolute">
      <parent>base_link</parent><child>wheel_br</child>
      <pose relative_to="base_link">-0.5 -0.65 0.0 0 0 0</pose>
      <axis><xyz>0 1 0</xyz><limit><lower>-1e+16</lower><upper>1e+16</upper><effort>100</effort><velocity>100</velocity></limit><dynamics><damping>0.05</damping></dynamics><use_parent_model_frame>1</use_parent_model_frame></axis>
    </joint>

    <!-- SCREEN -->
    <link name="screen_link">
      <pose relative_to="base_link">0 0 0 0 0 0</pose>
      <visual name="screen_visual"><geometry><mesh><uri>model://visnat/screen.stl</uri><scale>0.002 0.002 0.002</scale></mesh></geometry><material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material></visual>
    </link>
    <joint name="screen_joint" type="fixed"><parent>base_link</parent><child>screen_link</child></joint>

    <!-- CAMERA -->
    <link name="camera_link">
      <pose relative_to="base_link">0.40 0 0.60 0 0.2 0</pose>
      <visual name="camera_body"><geometry><box><size>0.06 0.25 0.06</size></box></geometry><material><ambient>0.08 0.08 0.08 1</ambient><diffuse>0.08 0.08 0.08 1</diffuse><specular>0.4 0.4 0.4 1</specular></material></visual>
      <visual name="lens_left"><pose>0.032 0.08 0 0 1.5708 0</pose><geometry><cylinder><radius>0.018</radius><length>0.012</length></cylinder></geometry><material><ambient>0.05 0.05 0.3 1</ambient><diffuse>0.05 0.05 0.3 1</diffuse></material></visual>
      <visual name="lens_rgb"><pose>0.032 0 0 0 1.5708 0</pose><geometry><cylinder><radius>0.016</radius><length>0.012</length></cylinder></geometry><material><ambient>0.3 0.15 0.0 1</ambient><diffuse>0.3 0.15 0.0 1</diffuse></material></visual>
      <visual name="lens_right"><pose>0.032 -0.08 0 0 1.5708 0</pose><geometry><cylinder><radius>0.018</radius><length>0.012</length></cylinder></geometry><material><ambient>0.05 0.05 0.3 1</ambient><diffuse>0.05 0.05 0.3 1</diffuse></material></visual>
      <sensor name="camera" type="rgbd_camera">
        <update_rate>30</update_rate><always_on>1</always_on><topic>camera</topic><gz_frame_id>camera_link</gz_frame_id>
        <camera><horizontal_fov>1.5184</horizontal_fov><image><width>800</width><height>450</height><format>R8G8B8</format></image><clip><near>0.05</near><far>20.0</far></clip><noise><type>gaussian</type><mean>0</mean><stddev>0.007</stddev></noise></camera>
      </sensor>
    </link>
    <joint name="camera_joint" type="fixed"><parent>base_link</parent><child>camera_link</child></joint>

    <!-- LIDAR -->
    <link name="lidar_link">
      <pose relative_to="base_link">0.28 0.28 0.67 0 0 0</pose>
      <visual name="lidar_body"><geometry><cylinder><radius>0.04</radius><length>0.06</length></cylinder></geometry><material><ambient>0.2 0.2 0.2 1</ambient><diffuse>0.2 0.2 0.2 1</diffuse><specular>0.5 0.5 0.5 1</specular></material></visual>
      <visual name="lidar_ring"><pose>0 0 0.035 0 0 0</pose><geometry><cylinder><radius>0.043</radius><length>0.012</length></cylinder></geometry><material><ambient>0.9 0.1 0.1 1</ambient><diffuse>0.9 0.1 0.1 1</diffuse></material></visual>
      <visual name="lidar_pole"><pose>0 0 -0.06 0 0 0</pose><geometry><cylinder><radius>0.01</radius><length>0.10</length></cylinder></geometry><material><ambient>0.3 0.3 0.3 1</ambient><diffuse>0.3 0.3 0.3 1</diffuse></material></visual>
      <sensor name="lidar" type="gpu_lidar">
        <update_rate>10</update_rate><topic>lidar</topic><gz_frame_id>lidar_link</gz_frame_id>
        <ray><scan><horizontal><samples>360</samples><resolution>1</resolution><min_angle>-3.14159</min_angle><max_angle>3.14159</max_angle></horizontal></scan><range><min>0.4</min><max>25.0</max><resolution>0.01</resolution></range></ray>
        <always_on>1</always_on><visualize>false</visualize>
      </sensor>
    </link>
    <joint name="lidar_joint" type="fixed"><parent>base_link</parent><child>lidar_link</child></joint>

    <!-- ================================================================ -->
    <!--  MANIPULATOR — 5 joints total                                     -->
    <!--                                                                    -->
    <!--  Joint 1 (manip_joint1): Z-axis YAW   — rotates arm sideways     -->
    <!--  Joint 2 (manip_joint2): X-axis PITCH  — shoulder                -->
    <!--  Joint 3 (manip_joint3): X-axis PITCH  — elbow                   -->
    <!--  Joint 4 (manip_joint4): X-axis PITCH  — wrist                   -->
    <!--  Joint 5 (manip_joint5): Y-axis ROLL   — end effector            -->
    <!--                                                                    -->
    <!--  Home: [0, 0.542, -2.9564, 0.8432, 0]                            -->
    <!--  Limits (deg): J1=±40  J2=[-32.5,+73]  J3=[-175,-38]            -->
    <!--                J4=[-63,+92]  J5=±40                              -->
    <!-- ================================================================ -->

    <!-- manip_base: fixed to mobile base, sits on top -->
    <link name="manip_base">
      <gravity>false</gravity>
      <pose relative_to="base_link">0 0 0.6 0 0 0</pose>
      <inertial><mass>2.0</mass><inertia><ixx>0.01</ixx><iyy>0.01</iyy><izz>0.01</izz></inertia></inertial>
      <visual name="manip_base_visual">
        <geometry><mesh><uri>model://visnat/Manipulator Base.stl</uri><scale>0.002 0.002 0.002</scale></mesh></geometry>
        <material><ambient>0.4 0.4 0.45 1</ambient><diffuse>0.4 0.4 0.45 1</diffuse><specular>0.6 0.6 0.6 1</specular></material>
      </visual>
      <collision name="manip_base_col"><geometry><cylinder><radius>0.10</radius><length>0.30</length></cylinder></geometry></collision>
    </link>
    <!-- manip_base is fixed to base_link — the ROTATION is joint1 below -->
    <joint name="manip_base_joint" type="fixed">
      <parent>base_link</parent>
      <child>manip_base</child>
    </joint>

    <!-- ── JOINT 1: Z-axis yaw, home=0.0, limits ±40° (±0.6981 rad) ── -->
    <link name="manip_link1">
      <gravity>false</gravity>
      <pose relative_to="manip_joint1">0 0 0.1 0 0 0</pose>
      <inertial><mass>1.0</mass><inertia><ixx>0.02</ixx><iyy>0.02</iyy><izz>0.01</izz></inertia></inertial>
      <visual name="link1_visual">
        <geometry><mesh><uri>model://visnat/Manipulator Link 1.stl</uri><scale>0.002 0.002 0.002</scale></mesh></geometry>
        <material><ambient>0.4 0.4 0.45 1</ambient><diffuse>0.4 0.4 0.45 1</diffuse><specular>0.6 0.6 0.6 1</specular></material>
      </visual>
      <collision name="link1_col"><geometry><cylinder><radius>0.10</radius><length>0.60</length></cylinder></geometry></collision>
    </link>
    <joint name="manip_joint1" type="revolute">
      <parent>manip_base</parent>
      <child>manip_link1</child>
      <pose relative_to="manip_base">0 0 0.2 0 0 0</pose>
      <axis>
        <xyz>0 0 1</xyz>
        <initial_position>0.0</initial_position>
        <limit><lower>-0.6981</lower><upper>0.6981</upper><effort>150</effort><velocity>2.0</velocity></limit>
        <dynamics><damping>50.0</damping><friction>5.0</friction><spring_reference>0</spring_reference><spring_stiffness>0</spring_stiffness></dynamics>
        <use_parent_model_frame>1</use_parent_model_frame>
      </axis>
    </joint>

    <!-- ── JOINT 2: X-axis pitch (shoulder), home=0.542, limits [-32.5°,+73°] ── -->
    <link name="manip_link2">
      <gravity>false</gravity>
      <pose relative_to="manip_joint2">0 0 -0.1 0 0 0</pose>
      <inertial><mass>0.7</mass><inertia><ixx>0.05</ixx><iyy>0.05</iyy><izz>0.05</izz></inertia></inertial>
      <visual name="link2_visual">
        <geometry><mesh><uri>model://visnat/Manipulator Link 2.stl</uri><scale>0.002 0.002 0.002</scale></mesh></geometry>
        <material><ambient>0.4 0.4 0.45 1</ambient><diffuse>0.4 0.4 0.45 1</diffuse><specular>0.6 0.6 0.6 1</specular></material>
      </visual>
      <collision name="link2_col"><pose>0 0 0.90 0 0 0</pose><geometry><cylinder><radius>0.08</radius><length>1.80</length></cylinder></geometry></collision>
    </link>
    <joint name="manip_joint2" type="revolute">
      <parent>manip_link1</parent>
      <child>manip_link2</child>
      <pose relative_to="manip_link1">0 0 0.4 0 0 0</pose>
      <axis>
        <xyz>1 0 0</xyz>
        <initial_position>0.3</initial_position>
        <limit><lower>-0.5668</lower><upper>1.2734</upper><effort>500</effort><velocity>2.0</velocity></limit>
        <dynamics><damping>10.0</damping><friction>0.5</friction><spring_reference>0</spring_reference><spring_stiffness>0</spring_stiffness></dynamics>
        <use_parent_model_frame>1</use_parent_model_frame>
      </axis>
    </joint>

    <!-- ── JOINT 3: X-axis pitch (elbow), home=-2.9564, limits [-175°,-38°] ── -->
    <link name="manip_link3">
      <gravity>false</gravity>
      <pose relative_to="manip_joint3">0 0 0 0 0 0</pose>
      <inertial><mass>0.5</mass><inertia><ixx>0.1</ixx><iyy>0.1</iyy><izz>0.005</izz></inertia></inertial>
      <visual name="link3_visual">
        <geometry><mesh><uri>model://visnat/Manipulator Link 3.stl</uri><scale>0.002 0.002 0.002</scale></mesh></geometry>
        <material><ambient>0.4 0.4 0.45 1</ambient><diffuse>0.4 0.4 0.45 1</diffuse><specular>0.6 0.6 0.6 1</specular></material>
      </visual>
      <collision name="link3_col"><pose>0 0 1.30 0 0 0</pose><geometry><cylinder><radius>0.08</radius><length>2.60</length></cylinder></geometry></collision>
    </link>
    <joint name="manip_joint3" type="revolute">
      <parent>manip_link2</parent>
      <child>manip_link3</child>
      <pose relative_to="manip_link2">0 0 1.8 3.14159 3.14159 3.14159</pose>
      <axis>
        <xyz>1 0 0</xyz>
        <initial_position>-2.55</initial_position>
        <limit><lower>-3.0543</lower><upper>-0.6557</upper><effort>1500</effort><velocity>2.0</velocity></limit>
        <dynamics><damping>10.0</damping><friction>0.5</friction><spring_reference>0</spring_reference><spring_stiffness>0</spring_stiffness></dynamics>
        <use_parent_model_frame>1</use_parent_model_frame>
      </axis>
    </joint>

    <!-- ── JOINT 4: X-axis pitch (wrist), home=0.8432, limits [-63°,+92°] ── -->
    <link name="manip_link4">
      <gravity>false</gravity>
      <pose relative_to="manip_joint4">0 0 0 0 0 0</pose>
      <inertial><mass>1.0</mass><inertia><ixx>0.01</ixx><iyy>0.01</iyy><izz>0.01</izz></inertia></inertial>
      <visual name="link4_visual">
        <geometry><mesh><uri>model://visnat/Manipulator Link 4.stl</uri><scale>0.002 0.002 0.002</scale></mesh></geometry>
        <material><ambient>0.4 0.4 0.45 1</ambient><diffuse>0.4 0.4 0.45 1</diffuse><specular>0.6 0.6 0.6 1</specular></material>
      </visual>
      <collision name="link4_col"><geometry><cylinder><radius>0.08</radius><length>0.40</length></cylinder></geometry></collision>
    </link>
    <joint name="manip_joint4" type="revolute">
      <parent>manip_link3</parent>
      <child>manip_link4</child>
      <pose relative_to="manip_link3">0 0 2.6 0 0 -1.5708</pose>
      <axis>
        <xyz>0 1 0</xyz>
        <initial_position>1.0</initial_position>
        <limit><lower>-1.0925</lower><upper>1.6044</upper><effort>500</effort><velocity>2.0</velocity></limit>
        <dynamics><damping>50.0</damping><friction>1.0</friction><spring_reference>0</spring_reference><spring_stiffness>0</spring_stiffness></dynamics>
        <use_parent_model_frame>1</use_parent_model_frame>
      </axis>
    </joint>

    <!-- ── JOINT 5: Y-axis roll (EE), home=0.0, limits ±40° ── -->
    <link name="manip_link5_ee">
      <gravity>false</gravity>
      <pose relative_to="manip_joint5">0 0 0 0 0 0</pose>
      <inertial><mass>0.5</mass><inertia><ixx>0.01</ixx><iyy>0.01</iyy><izz>0.01</izz></inertia></inertial>
      <visual name="link5_visual">
        <pose>0 0 0 0 0 0</pose>
        <geometry><mesh><uri>model://visnat/Manipulator Link 5 EE.stl</uri><scale>0.002 0.002 0.002</scale></mesh></geometry>
        <material><ambient>0.35 0.35 0.4 1</ambient><diffuse>0.35 0.35 0.4 1</diffuse><specular>0.7 0.7 0.7 1</specular></material>
      </visual>
      <collision name="link5_col"><geometry><box><size>0.15 0.15 0.30</size></box></geometry></collision>
    </link>
	<joint name="manip_joint5" type="revolute">
	  <parent>manip_link4</parent>
	  <child>manip_link5_ee</child>
	  <pose relative_to="manip_link4">0 0 0.2 1.5708 0 1.5708</pose>
	  <axis>
	    <xyz>0 0 1</xyz>
	    <initial_position>0</initial_position>
	    <limit><lower>-0.6981</lower><upper>0.6981</upper><effort>500</effort><velocity>2.0</velocity></limit>
	    <dynamics><damping>50.0</damping><friction>1.0</friction><spring_reference>0</spring_reference><spring_stiffness>0</spring_stiffness></dynamics>
	  </axis>
	</joint>

    <!-- ================================================================ -->
    <!--  JOINT POSITION CONTROLLERS                                        -->
    <!--  Home: [0.0, 0.542, -2.9564, 0.8432, 0.0]                       -->
    <!-- ================================================================ -->
    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>manip_joint1</joint_name>
      <topic>/model/wall_painting_robot/joint1/cmd_pos</topic>
      <initial_position>0.0</initial_position>
      <p_gain>100</p_gain><i_gain>0.0</i_gain><d_gain>10</d_gain>
      <i_max>0</i_max><i_min>0</i_min><cmd_max>150</cmd_max><cmd_min>-150</cmd_min>
    </plugin>

    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>manip_joint2</joint_name>
      <topic>/model/wall_painting_robot/joint2/cmd_pos</topic>
      <initial_position>0.30</initial_position>
      <p_gain>300</p_gain><i_gain>0.0</i_gain><d_gain>150</d_gain>
      <i_max>10</i_max><i_min>-10</i_min><cmd_max>1500</cmd_max><cmd_min>-1500</cmd_min>
    </plugin>

    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>manip_joint3</joint_name>
      <topic>/model/wall_painting_robot/joint3/cmd_pos</topic>
      <initial_position>-2.55</initial_position>
      <p_gain>300</p_gain><i_gain>0.0</i_gain><d_gain>150</d_gain>
      <i_max>10</i_max><i_min>-10</i_min><cmd_max>1500</cmd_max><cmd_min>-1500</cmd_min>
    </plugin>

    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>manip_joint4</joint_name>
      <topic>/model/wall_painting_robot/joint4/cmd_pos</topic>
      <initial_position>1.0</initial_position>
      <p_gain>400</p_gain><i_gain>0.1</i_gain><d_gain>150</d_gain>
      <i_max>10</i_max><i_min>-10</i_min><cmd_max>1500</cmd_max><cmd_min>-1500</cmd_min>
    </plugin>

    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>manip_joint5</joint_name>
      <topic>/model/wall_painting_robot/joint5/cmd_pos</topic>
      <initial_position>0.0</initial_position>
      <p_gain>100</p_gain><i_gain>0.0</i_gain><d_gain>10</d_gain>
      <i_max>0</i_max><i_min>0</i_min><cmd_max>50</cmd_max><cmd_min>-50</cmd_min>
    </plugin>

    <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">
      <topic>/model/wall_painting_robot/joint_states</topic>
      <joint_name>manip_joint1</joint_name>
      <joint_name>manip_joint2</joint_name>
      <joint_name>manip_joint3</joint_name>
      <joint_name>manip_joint4</joint_name>
      <joint_name>manip_joint5</joint_name>
      <joint_name>joint_fl</joint_name>
      <joint_name>joint_fr</joint_name>
      <joint_name>joint_bl</joint_name>
      <joint_name>joint_br</joint_name>
    </plugin>

    <!-- ================================================================ -->
    <!--  DIFF DRIVE                                                        -->
    <!-- ================================================================ -->
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>joint_fl</left_joint><left_joint>joint_bl</left_joint>
      <right_joint>joint_fr</right_joint><right_joint>joint_br</right_joint>
      <wheel_separation>1.3</wheel_separation><wheel_radius>0.1</wheel_radius>
      <max_linear_acceleration>1</max_linear_acceleration><min_linear_acceleration>-1</min_linear_acceleration>
      <max_angular_acceleration>0.5</max_angular_acceleration><min_angular_acceleration>-0.5</min_angular_acceleration>
      <max_linear_velocity>5</max_linear_velocity><min_linear_velocity>-5</min_linear_velocity>
      <max_angular_velocity>4</max_angular_velocity><min_angular_velocity>-4</min_angular_velocity>
      <topic>cmd_vel</topic>
      <odom_topic>/model/wall_painting_robot/odometry</odom_topic>
      <frame_id>odom</frame_id><child_frame_id>base_footprint</child_frame_id>
      <publish_tf>true</publish_tf><odom_publish_frequency>30</odom_publish_frequency>
    </plugin>

  </model>
</sdf>

