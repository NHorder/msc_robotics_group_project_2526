<?xml version="1.0"?>
<robot name="visnat" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ============================================================ -->
  <!--  MATERIALS                                                     -->
  <!-- ============================================================ -->
  <material name="dark_grey"><color rgba="0.1 0.1 0.1 1"/></material>
  <material name="grey"><color rgba="0.4 0.4 0.45 1"/></material>

  <!-- ============================================================ -->
  <!--  MOBILE BASE                                                   -->
  <!-- ============================================================ -->
  <link name="base_footprint"/>

  <joint name="footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <inertial>
      <mass value="200"/>
      <inertia ixx="50.0" ixy="0" ixz="0" iyy="50.0" iyz="0" izz="80.0"/>
    </inertial>
    <collision>
      <origin xyz="0 0 0.07" rpy="0 0 0"/>
      <geometry><box size="0.6 0.6 0.06"/></geometry>
    </collision>
    <visual>
      <geometry>
        <mesh filename="model://visnat/base.stl" scale="0.002 0.002 0.002"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
  </link>

  <!-- WHEELS -->
  <link name="wheel_fl">
    <inertial><mass value="1.0"/><inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.005"/></inertial>
    <visual><geometry><mesh filename="model://visnat/wheel.stl" scale="0.002 0.002 0.002"/></geometry><material name="dark_grey"/></visual>
    <collision><origin xyz="0 0 0" rpy="1.5708 0 0"/><geometry><cylinder radius="0.1" length="0.05"/></geometry></collision>
  </link>
  <joint name="joint_fl" type="continuous">
    <parent link="base_link"/><child link="wheel_fl"/>
    <origin xyz="0.5 0.65 0.0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.05"/>
  </joint>

  <link name="wheel_fr">
    <inertial><mass value="1.0"/><inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.005"/></inertial>
    <visual><geometry><mesh filename="model://visnat/wheel.stl" scale="0.002 0.002 0.002"/></geometry><material name="dark_grey"/></visual>
    <collision><origin xyz="0 0 0" rpy="1.5708 0 0"/><geometry><cylinder radius="0.1" length="0.05"/></geometry></collision>
  </link>
  <joint name="joint_fr" type="continuous">
    <parent link="base_link"/><child link="wheel_fr"/>
    <origin xyz="0.5 -0.65 0.0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.05"/>
  </joint>

  <link name="wheel_bl">
    <inertial><mass value="1.0"/><inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.005"/></inertial>
    <visual><geometry><mesh filename="model://visnat/wheel.stl" scale="0.002 0.002 0.002"/></geometry><material name="dark_grey"/></visual>
    <collision><origin xyz="0 0 0" rpy="1.5708 0 0"/><geometry><cylinder radius="0.1" length="0.05"/></geometry></collision>
  </link>
  <joint name="joint_bl" type="continuous">
    <parent link="base_link"/><child link="wheel_bl"/>
    <origin xyz="-0.5 0.65 0.0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.05"/>
  </joint>

  <link name="wheel_br">
    <inertial><mass value="1.0"/><inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.005"/></inertial>
    <visual><geometry><mesh filename="model://visnat/wheel.stl" scale="0.002 0.002 0.002"/></geometry><material name="dark_grey"/></visual>
    <collision><origin xyz="0 0 0" rpy="1.5708 0 0"/><geometry><cylinder radius="0.1" length="0.05"/></geometry></collision>
  </link>
  <joint name="joint_br" type="continuous">
    <parent link="base_link"/><child link="wheel_br"/>
    <origin xyz="-0.5 -0.65 0.0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.05"/>
  </joint>

  <!-- LIDAR -->
  <link name="lidar_link">
    <inertial><mass value="0.1"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/></inertial>
    <visual><origin xyz="0 0 0" rpy="0 0 0"/><geometry><cylinder radius="0.04" length="0.06"/></geometry><material name="dark_grey"/></visual>
  </link>
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/><child link="lidar_link"/>
    <origin xyz="0.28 0.28 0.67" rpy="0 0 0"/>
  </joint>

  <!-- CAMERA -->
  <link name="camera_link">
    <inertial><mass value="0.1"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/></inertial>
    <visual><geometry><box size="0.06 0.25 0.06"/></geometry><material name="dark_grey"/></visual>
  </link>
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/><child link="camera_link"/>
    <origin xyz="0.40 0 0.60" rpy="0 0.2 0"/>
  </joint>

  <!-- ============================================================ -->
  <!--  MANIPULATOR ARM                                               -->
  <!--  5 DOF: joint1=yaw, joint2=shoulder, joint3=elbow,           -->
  <!--         joint4=wrist, joint5=EE roll                          -->
  <!-- ============================================================ -->

  <!-- manip_base is fixed to base_link -->
  <link name="manip_base">
    <inertial><mass value="2.0"/><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/></inertial>
    <visual>
      <geometry><mesh filename="model://visnat/Manipulator Base.stl" scale="0.002 0.002 0.002"/></geometry>
      <material name="grey"/>
    </visual>
    <collision><geometry><cylinder radius="0.10" length="0.30"/></geometry></collision>
  </link>
  <joint name="manip_base_joint" type="fixed">
    <parent link="base_link"/><child link="manip_base"/>
    <origin xyz="0 0 0.6" rpy="0 0 0"/>
  </joint>

  <!-- JOINT 1: Z yaw — rotates arm sideways -->
  <link name="manip_link1">
    <inertial><mass value="1.0"/><inertia ixx="0.02" ixy="0" ixz="0" iyy="0.02" iyz="0" izz="0.01"/></inertial>
    <visual>
      <geometry><mesh filename="model://visnat/Manipulator Link 1.stl" scale="0.002 0.002 0.002"/></geometry>
      <material name="grey"/>
    </visual>
    <collision><geometry><cylinder radius="0.10" length="0.60"/></geometry></collision>
  </link>
  <joint name="manip_joint1" type="revolute">
    <parent link="manip_base"/><child link="manip_link1"/>
    <origin xyz="0 0 0.2" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.6981" upper="0.6981" effort="150" velocity="2.0"/>
    <dynamics damping="50.0" friction="2.0"/>
  </joint>

  <!-- JOINT 2: X shoulder pitch -->
  <link name="manip_link2">
    <inertial><mass value="0.5"/><inertia ixx="0.05" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.005"/></inertial>
    <visual>
      <geometry><mesh filename="model://visnat/Manipulator Link 2.stl" scale="0.002 0.002 0.002"/></geometry>
      <material name="grey"/>
    </visual>
    <!-- No collision — arm passes through wall -->
  </link>
  <joint name="manip_joint2" type="revolute">
    <!-- link1 child offset: joint at 0 0 0.4 relative to link1, link2 origin at 0 0 -0.1 relative to joint2 -->
    <parent link="manip_link1"/><child link="manip_link2"/>
    <origin xyz="0 0 0.3" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.5668" upper="1.2734" effort="1000" velocity="2.0"/>
    <dynamics damping="10.0" friction="0.5"/>
  </joint>

  <!-- JOINT 3: X elbow pitch (axis flipped via rpy) -->
  <link name="manip_link3">
    <inertial><mass value="0.5"/><inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.005"/></inertial>
    <visual>
      <geometry><mesh filename="model://visnat/Manipulator Link 3.stl" scale="0.002 0.002 0.002"/></geometry>
      <material name="grey"/>
    </visual>
    <!-- No collision -->
  </link>
  <joint name="manip_joint3" type="revolute">
    <!-- pose relative to link2: 0 0 1.8, rpy 3.14159 3.14159 3.14159 (axis flip) -->
    <parent link="manip_link2"/><child link="manip_link3"/>
    <origin xyz="0 0 1.8" rpy="3.14159 3.14159 3.14159"/>
    <axis xyz="1 0 0"/>
    <limit lower="-3.0543" upper="-0.6557" effort="1500" velocity="2.0"/>
    <dynamics damping="10.0" friction="0.5"/>
  </joint>

  <!-- JOINT 4: Y wrist pitch -->
  <link name="manip_link4">
    <inertial><mass value="0.5"/><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/></inertial>
    <visual>
      <geometry><mesh filename="model://visnat/Manipulator Link 4.stl" scale="0.002 0.002 0.002"/></geometry>
      <material name="grey"/>
    </visual>
    <!-- No collision -->
  </link>
  <joint name="manip_joint4" type="revolute">
    <parent link="manip_link3"/><child link="manip_link4"/>
    <origin xyz="0 0 2.6" rpy="0 0 -1.5708"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.0925" upper="1.6044" effort="500" velocity="2.0"/>
    <dynamics damping="10.0" friction="0.5"/>
  </joint>

  <!-- JOINT 5: EE roll -->
  <link name="manip_link5_ee">
    <inertial><mass value="0.3"/><inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.005"/></inertial>
    <visual>
      <geometry><mesh filename="model://visnat/Manipulator Link 5 EE.stl" scale="0.002 0.002 0.002"/></geometry>
      <material name="grey"/>
    </visual>
    <!-- No collision -->
  </link>
  <joint name="manip_joint5" type="revolute">
    <parent link="manip_link4"/><child link="manip_link5_ee"/>
    <origin xyz="0 0 0.2" rpy="1.5708 0 1.5708"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.6981" upper="0.6981" effort="50" velocity="2.0"/>
    <dynamics damping="10.0" friction="0.5"/>
  </joint>

  <!-- tool0: MoveIt end-effector reference frame -->
  <link name="tool0"/>
  <joint name="tool0_joint" type="fixed">
    <parent link="manip_link5_ee"/><child link="tool0"/>
    <origin xyz="0 0 0.15" rpy="0 0 0"/>
  </joint>

  <!-- ============================================================ -->
  <!--  ROS2_CONTROL — replaces individual JointPositionControllers  -->
  <!-- ============================================================ -->
  <ros2_control name="visnat_arm" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    <joint name="manip_joint1">
      <command_interface name="position">
        <param name="min">-0.6981</param>
        <param name="max">0.6981</param>
      </command_interface>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="manip_joint2">
      <command_interface name="position">
        <param name="min">-0.5668</param>
        <param name="max">1.2734</param>
      </command_interface>
      <state_interface name="position"><param name="initial_value">0.25</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="manip_joint3">
      <command_interface name="position">
        <param name="min">-3.0543</param>
        <param name="max">-0.6557</param>
      </command_interface>
      <state_interface name="position"><param name="initial_value">-0.70</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="manip_joint4">
      <command_interface name="position">
        <param name="min">-1.0925</param>
        <param name="max">1.6044</param>
      </command_interface>
      <state_interface name="position"><param name="initial_value">0.50</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="manip_joint5">
      <command_interface name="position">
        <param name="min">-0.6981</param>
        <param name="max">0.6981</param>
      </command_interface>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <!-- ============================================================ -->
  <!--  GAZEBO PLUGINS                                               -->
  <!-- ============================================================ -->

  <!-- gz_ros2_control replaces individual JointPositionController plugins -->
  <gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find wall_painting_robot)/config/controllers.yaml</parameters>
    </plugin>
  </gazebo>

  <!-- Diff drive for mobile base -->
  <gazebo>
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>joint_fl</left_joint>
      <left_joint>joint_bl</left_joint>
      <right_joint>joint_fr</right_joint>
      <right_joint>joint_br</right_joint>
      <wheel_separation>1.3</wheel_separation>
      <wheel_radius>0.1</wheel_radius>
      <topic>cmd_vel</topic>
      <odom_topic>/model/wall_painting_robot/odometry</odom_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
      <publish_tf>true</publish_tf>
      <odom_publish_frequency>30</odom_publish_frequency>
    </plugin>
  </gazebo>

  <!-- Joint state publisher for nav/viz -->
  <gazebo>
    <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">
      <topic>/model/wall_painting_robot/joint_states</topic>
      <joint_name>manip_joint1</joint_name>
      <joint_name>manip_joint2</joint_name>
      <joint_name>manip_joint3</joint_name>
      <joint_name>manip_joint4</joint_name>
      <joint_name>manip_joint5</joint_name>
    </plugin>
  </gazebo>

  <!-- Disable gravity on arm links -->
  <gazebo reference="manip_link1"><gravity>0</gravity></gazebo>
  <gazebo reference="manip_link2"><gravity>0</gravity></gazebo>
  <gazebo reference="manip_link3"><gravity>0</gravity></gazebo>
  <gazebo reference="manip_link4"><gravity>0</gravity></gazebo>
  <gazebo reference="manip_link5_ee"><gravity>0</gravity></gazebo>

  <!-- Lidar sensor -->
  <gazebo reference="lidar_link">
    <sensor name="lidar" type="gpu_lidar">
      <update_rate>10</update_rate><topic>lidar</topic><gz_frame_id>lidar_link</gz_frame_id>
      <ray><scan><horizontal><samples>360</samples><resolution>1</resolution><min_angle>-3.14159</min_angle><max_angle>3.14159</max_angle></horizontal></scan><range><min>0.4</min><max>25.0</max><resolution>0.01</resolution></range></ray>
      <always_on>1</always_on><visualize>false</visualize>
    </sensor>
  </gazebo>

  <!-- Camera sensor -->
  <gazebo reference="camera_link">
    <sensor name="camera" type="rgbd_camera">
      <update_rate>30</update_rate><always_on>1</always_on><topic>camera</topic><gz_frame_id>camera_link</gz_frame_id>
      <camera><horizontal_fov>1.5184</horizontal_fov><image><width>800</width><height>450</height><format>R8G8B8</format></image><clip><near>0.05</near><far>20.0</far></clip></camera>
    </sensor>
  </gazebo>
  
  <passive_joint name="joint_fl"/>
  <passive_joint name="joint_fr"/>
  <passive_joint name="joint_bl"/>
  <passive_joint name="joint_br"/>

</robot>

